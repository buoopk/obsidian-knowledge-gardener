{
    "name": "obsidian-knowledge-gardener",
    "version": "1.0.0",
    "description": "Knowledge Gardener plugin for Obsidian",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "dev:free": "node esbuild.config.mjs free",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "build:free": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production free",
        "build:pro": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production pro",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint ."
    },
    "keywords": [],
    "license": "0-BSD",
    "devDependencies": {
        "@eslint/js": "9.30.1",
        "@types/node": "^16.11.6",
        "esbuild": "0.25.5",
        "eslint-plugin-obsidianmd": "0.1.9",
        "globals": "14.0.0",
        "jiti": "2.6.1",
        "tslib": "2.4.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "8.35.1"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}